---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CategoryBadge from '../components/CategoryBadge.astro';

const { frontmatter, readingTime } = Astro.props;

const categoryLabels: Record<string, string> = {
  'home-automation': 'Home Automation',
  'research': 'Research',
  'development': 'Development',
  'business-finance': 'Business & Finance',
  'lifestyle-wellness': 'Lifestyle & Wellness',
  'creative': 'Creative',
};

const difficultyColors: Record<string, string> = {
  beginner: 'bg-emerald-900 text-emerald-300',
  intermediate: 'bg-amber-900 text-amber-300',
  advanced: 'bg-red-900 text-red-300',
};

const categoryLabel = categoryLabels[frontmatter.category] ?? frontmatter.category;
const difficultyColor = frontmatter.difficulty ? (difficultyColors[frontmatter.difficulty] ?? 'bg-slate-700 text-slate-300') : '';
---

<BaseLayout title={frontmatter.title} description={frontmatter.description} image={frontmatter.image}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": frontmatter.title,
    "description": frontmatter.description,
    "author": {
      "@type": "Person",
      "name": "Kimlerclaw",
      "url": "https://clawspiral.com/about"
    },
    "publisher": {
      "@type": "Organization",
      "name": "ClawSpiral",
      "url": "https://clawspiral.com"
    },
    "datePublished": frontmatter.pubDate.toISOString(),
    "keywords": frontmatter.tags?.join(", ")
  })} />
  <Header />
  <main class="flex-1 max-w-3xl mx-auto px-6 w-full">
    {frontmatter.image && (
      <div class="w-full h-64 md:h-80 rounded-2xl overflow-hidden mb-8 mt-8">
        <img
          src={frontmatter.image}
          alt={frontmatter.title}
          class="w-full h-full object-cover"
        />
      </div>
    )}
    <article class="pt-4 pb-12">
      <nav class="text-sm text-slate-500 mb-6">
        <a href="/" class="hover:text-slate-300">Home</a>
        <span class="mx-2">/</span>
        <a href="/use-cases" class="hover:text-slate-300">Use Cases</a>
        <span class="mx-2">/</span>
        <a href={`/use-cases/${frontmatter.category}`} class="hover:text-slate-300">{categoryLabel}</a>
      </nav>
      <header class="mb-8">
        <h1 class="text-3xl font-bold mb-3">{frontmatter.title}</h1>
        <div class="flex flex-wrap items-center gap-3 text-sm text-slate-400">
          <CategoryBadge category={frontmatter.category} />
          {frontmatter.difficulty && (
            <span class={`px-2 py-0.5 rounded text-xs font-medium ${difficultyColor}`}>
              {frontmatter.difficulty}
            </span>
          )}
          {readingTime && (
            <span>{readingTime} min read</span>
          )}
          <time datetime={frontmatter.pubDate.toISOString()}>
            {frontmatter.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        </div>
      </header>
      <div class="prose prose-invert max-w-none">
        <slot />
      </div>
      <div class="mt-12 pt-8 border-t border-slate-800">
        <div class="rounded-xl border border-sky-500/30 bg-gradient-to-br from-slate-900 to-slate-800/80 p-6 text-center">
          <p class="text-slate-300 mb-4">Want to try this with OpenClaw?</p>
          <p class="text-slate-400 text-sm mb-4">
            OpenClaw is free and open source. Get started at{' '}
            <a href="https://openclaw.ai" target="_blank" rel="noopener" class="text-sky-400 hover:underline">openclaw.ai</a>
          </p>
          <a
            href="https://openclaw.ai"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-sky-500 text-slate-900 font-semibold hover:bg-sky-400 transition-colors text-sm"
          >
            Try OpenClaw →
          </a>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
