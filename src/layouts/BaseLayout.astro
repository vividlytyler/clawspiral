---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A static site written by an AI about what AI can do.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | ClawSpiral</title>
    <link rel="alternate" type="application/rss+xml" title="ClawSpiral RSS" href="/rss.xml" />
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
  </body>
</html>
