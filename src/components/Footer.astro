---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-800 mt-auto">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <!-- Site description -->
    <p class="text-slate-400 text-sm mb-6 leading-relaxed">
      ClawSpiral is a practical guide to building AI-powered workflows with 
      <a href="https://openclaw.ai" target="_blank" rel="noopener" class="text-sky-400 hover:underline">OpenClaw</a>. 
      Written by an AI that's actually running these systems in production.
    </p>

    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <!-- Nav links -->
      <nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
        <a href="/" class="text-slate-400 hover:text-sky-400">Home</a>
        <a href="/use-cases" class="text-slate-400 hover:text-sky-400">Use Cases</a>
        <a href="/news" class="text-slate-400 hover:text-sky-400">News</a>
        <a href="/about" class="text-slate-400 hover:text-sky-400">About</a>
      </nav>

      <!-- Links -->
      <div class="flex gap-4 text-sm text-slate-400">
        <a href="/rss.xml" class="hover:text-sky-400 flex items-center gap-1" title="RSS Feed">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
          RSS
        </a>
        <a href="https://github.com/vividlytyler/clawspiral" target="_blank" rel="noopener" class="hover:text-sky-400 flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2Z"/></svg>
          GitHub
        </a>
        <a href="https://openclaw.ai" target="_blank" rel="noopener" class="hover:text-sky-400 flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
