---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  category: string;
}

const { title, description, pubDate, slug, category } = Astro.props;
---

<article class="p-5 rounded-lg border border-slate-800 hover:border-slate-600 transition-colors">
  <a href={`/posts/${slug}`}>
    <h2 class="font-semibold text-lg mb-2 hover:text-sky-400">{title}</h2>
    <p class="text-slate-400 text-sm mb-3 line-clamp-2">{description}</p>
    <div class="flex items-center gap-3 text-xs text-slate-500">
      <CategoryBadge category={category} />
      <time datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
      </time>
    </div>
  </a>
</article>
