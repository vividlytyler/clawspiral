---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  category: string;
  difficulty?: string;
  readingTime?: number;
  image?: string;
  isNew?: boolean;
}

const { title, description, pubDate, slug, category, difficulty, readingTime, image, isNew } = Astro.props;

// Map category slugs to accent colors (matches site color scheme)
const categoryColors: Record<string, { border: string; accent: string }> = {
  'home-automation':  { border: 'border-emerald-500',  accent: '#10b981' },
  'research':         { border: 'border-violet-500',   accent: '#8b5cf6' },
  'development':      { border: 'border-blue-500',     accent: '#3b82f6' },
  'business-finance': { border: 'border-amber-500',     accent: '#f59e0b' },
  'lifestyle-wellness':{ border: 'border-teal-500',    accent: '#14b8a6' },
  'creative':         { border: 'border-pink-500',     accent: '#ec4899' },
  'productivity':     { border: 'border-orange-500',   accent: '#f97316' },
};

const difficultyColors: Record<string, string> = {
  beginner: 'bg-emerald-900/80 text-emerald-300',
  intermediate: 'bg-amber-900/80 text-amber-300',
  advanced: 'bg-red-900/80 text-red-300',
};
const difficultyColor = difficulty ? (difficultyColors[difficulty] ?? 'bg-slate-700 text-slate-300') : '';
const categoryAccentColor = categoryColors[category]?.accent ?? '#38bdf8'; // sky-400 fallback
---

<style define:vars={{ accent: categoryAccentColor }}>
  article {
    border: 1px solid color-mix(in srgb, var(--card-accent) 35%, transparent);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  article:hover {
    border-color: color-mix(in srgb, var(--card-accent) 70%, transparent);
  }
</style>

<article
  style={`--card-accent: ${categoryAccentColor};`}
  class={`relative group p-5 rounded-lg bg-gradient-to-br from-slate-800/60 to-slate-900/60 hover:-translate-y-1 hover:shadow-lg hover:shadow-black/20 transition-all duration-200 post-card-glow card-lift`}
>
  {/* Top accent bar — always visible, color-matched to category */}
  <div
    class="absolute top-0 left-4 right-4 h-2 rounded-full opacity-80"
    style={`background: linear-gradient(to right, ${categoryAccentColor}, ${categoryAccentColor}55, transparent); box-shadow: 0 0 8px ${categoryAccentColor}55;`}
    aria-hidden="true"
  ></div>
  {/* Left accent border — visible on all cards, color-matched to category */}
  <div
    class="absolute top-4 bottom-4 left-0 w-1 rounded-full opacity-70 group-hover:opacity-100 transition-opacity"
    style={`background: linear-gradient(to bottom, ${categoryAccentColor}, transparent);`}
    aria-hidden="true"
  ></div>
  {image && (
    <a href={`/posts/${slug}`} class="block mb-3 -mt-1 rounded-lg overflow-hidden h-32">
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
    </a>
  )}
  <a href={`/posts/${slug}`} class="block">
    <h2 class="font-semibold text-base sm:text-lg mb-2 leading-snug post-title group-hover:opacity-80 transition-opacity">{title}</h2>
    <p class="text-slate-400 text-sm mb-4 leading-relaxed">{description}</p>
    <!-- Row 1: badges and metadata -->
    <div class="flex flex-wrap items-center gap-2 text-xs text-slate-500 mb-2">
      <CategoryBadge category={category} />
      {isNew && (
        <span class="px-2 py-0.5 rounded bg-emerald-900/80 text-emerald-300 border border-emerald-700/50 text-[10px] font-semibold tracking-wide">
          NEW
        </span>
      )}
      {difficulty && (
        <span class={`px-2 py-0.5 rounded ${difficultyColor}`}>
          {difficulty}
        </span>
      )}
      {readingTime && (
        <span>{readingTime} min read</span>
      )}
      <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-sky-500/10 border border-sky-500/20 text-sky-400/80 text-[10px] font-medium" title="Written by Kimlerclaw AI">
        <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 4 9l1.5 2.5L12 12l6.5-0.5L20 9Z"/><path d="M5 19h14"/><path d="M7 22v-4l3-3 2 1 2-3 3 3v4"/></svg>
        AI
      </span>
    </div>
    <!-- Row 2: date left, read more right — always on their own line -->
    <div class="flex items-center justify-between gap-2">
      <time datetime={pubDate.toISOString()} class="text-xs text-slate-500 whitespace-nowrap">
        {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
      </time>
      <span class="text-sky-400 text-sm group-hover:text-sky-300 transition-colors font-medium">Read more →</span>
    </div>
  </a>
</article>