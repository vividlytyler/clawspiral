---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  category: string;
  difficulty?: string;
  readingTime?: number;
  image?: string;
  borderColor?: string;
}

const { title, description, pubDate, slug, category, difficulty, readingTime, image, borderColor } = Astro.props;

// Map category slugs to border colors (matches site color scheme)
const categoryColors: Record<string, string> = {
  'home-automation': '#10b981',   // emerald-500
  'research':        '#8b5cf6',   // violet-500
  'development':     '#3b82f6',   // blue-500
  'business-finance':'#f59e0b',  // amber-500
  'lifestyle-wellness':'#14b8a6', // teal-500
  'creative':        '#ec4899',   // pink-500
};
const resolvedColor = borderColor ?? categoryColors[category] ?? null;
const borderStyle = resolvedColor
  ? `border-left: 3px solid ${resolvedColor};`
  : '';

const difficultyColors: Record<string, string> = {
  beginner: 'bg-emerald-900/80 text-emerald-300',
  intermediate: 'bg-amber-900/80 text-amber-300',
  advanced: 'bg-red-900/80 text-red-300',
};
const difficultyColor = difficulty ? (difficultyColors[difficulty] ?? 'bg-slate-700 text-slate-300') : '';
---

<article class="p-5 rounded-lg border border-slate-800 hover:border-slate-600 transition-colors" style={borderStyle}>
  <a href={`/posts/${slug}`} class="flex gap-4">
    {image && (
      <img 
        src={image} 
        alt="" 
        class="w-24 h-16 object-cover rounded-md flex-shrink-0 opacity-80 hover:opacity-100 transition-opacity"
      />
    )}
    <div class="flex-1 min-w-0">
      <h2 class="font-semibold text-lg mb-2 hover:text-sky-400">{title}</h2>
      <p class="text-slate-400 text-sm mb-3 line-clamp-2">{description}</p>
      <div class="flex flex-wrap items-center gap-3 text-xs text-slate-500">
        <CategoryBadge category={category} />
        {difficulty && (
          <span class={`px-2 py-0.5 rounded ${difficultyColor}`}>
            {difficulty}
          </span>
        )}
        {readingTime && (
          <span>{readingTime} min read</span>
        )}
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
        </time>
      </div>
    </div>
  </a>
</article>
