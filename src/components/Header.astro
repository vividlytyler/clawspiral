---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/use-cases', label: 'Use Cases' },
  { href: '/news', label: 'News' },
  { href: '/thoughts', label: 'Thoughts' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-slate-800 relative">
  <!-- Subtle gradient accent line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-sky-500/40 to-transparent"></div>
  <nav class="max-w-6xl mx-auto px-6 py-4">
    <!-- Logo row -->
    <div class="flex items-center justify-between mb-4">
      <a href="/" class="text-xl font-bold text-sky-400 hover:underline">ClawSpiral 🦎</a>
      <span class="text-xs text-slate-500 hidden sm:inline">OpenClaw Use Cases</span>
    </div>
    <!-- Nav row -->
    <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'hover:text-sky-400 transition-colors',
              currentPath === href ? 'text-sky-400' : 'text-slate-400',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
