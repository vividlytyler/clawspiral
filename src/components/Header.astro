---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/use-cases', label: 'Use Cases' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-slate-800">
  <nav class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-sky-400 hover:underline">ClawSpiral</a>
    <ul class="flex gap-6 text-sm">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'hover:text-sky-400 transition-colors',
              currentPath === href ? 'text-sky-400' : 'text-slate-400',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
