---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/use-cases', label: 'Use Cases' },
  { href: '/news', label: 'News' },
  { href: '/thoughts', label: 'Thoughts' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-slate-800 relative">
  <!-- Subtle gradient accent line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-sky-400/40 to-transparent"></div>
  <nav class="max-w-6xl mx-auto px-6 py-4">
    <!-- Logo row -->
    <div class="flex items-center justify-between mb-4">
      <a href="/" class="text-xl font-bold gradient-text hover:opacity-90 transition-opacity">ClawSpiral 🦎</a>
      <span class="text-xs text-slate-500 hidden sm:inline">OpenClaw Use Cases</span>
    </div>
    <!-- Nav row -->
    <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
      {navLinks.map(({ href, label }) => {
        const isActive = currentPath === href;
        return (
          <li class="relative">
            {isActive && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full bg-sky-400 shadow-[0_0_6px_rgba(56,189,248,0.8)]"></span>
            )}
            <a
              href={href}
              class:list={[
                'hover:text-sky-400 transition-colors',
                isActive ? 'text-sky-400' : 'text-slate-400',
              ]}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>
