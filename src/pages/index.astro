---
import PageLayout from '../layouts/PageLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const featuredPosts = allPosts.filter((post) => post.data.featured).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 5);

function getReadingTime(body: string | undefined): number {
  if (!body) return 1;
  return Math.max(1, Math.ceil(body.split(/\s+/).length / 200));
}

const categories = [
  { 
    slug: 'home-automation', 
    label: 'Home Automation', 
    desc: 'Smart home, IoT, routines',
    image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&h=200&fit=crop'
  },
  { 
    slug: 'research', 
    label: 'Research', 
    desc: 'Web research, data gathering, synthesis',
    image: 'https://images.unsplash.com/photo-1456324504439-367cee3b3c32?w=400&h=200&fit=crop'
  },
  { 
    slug: 'development', 
    label: 'Development', 
    desc: 'Coding, debugging, CI/CD, tooling',
    image: 'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=400&h=200&fit=crop'
  },
  { 
    slug: 'business-finance', 
    label: 'Business & Finance', 
    desc: 'ROI-focused tools, admin automation, financial workflows',
    image: 'https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?w=400&h=200&fit=crop'
  },
  { 
    slug: 'lifestyle-wellness', 
    label: 'Lifestyle & Wellness', 
    desc: 'Personal habits, health, travel, daily routines',
    image: 'https://images.unsplash.com/photo-1506784983877-45594efa4cbe?w=400&h=200&fit=crop'
  },
  { 
    slug: 'creative', 
    label: 'Creative', 
    desc: 'Writing, art, music prompts, brainstorming',
    image: 'https://images.unsplash.com/photo-1513364776144-60967b0f800f?w=400&h=200&fit=crop'
  },
  
];
---

<PageLayout title="Home">
  <!-- Hero Section -->
  <section class="mb-12 relative overflow-hidden rounded-2xl glow">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900"></div>
    <div class="relative z-10 p-10 md:p-16">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-6 tracking-tight leading-tight">
        Meet <span class="gradient-text">OpenClaw</span> —<br class="hidden md:block" />
        the AI agent that runs your life
      </h1>
      <p class="text-slate-300 max-w-2xl text-xl leading-relaxed mb-8">
        Most AI tools answer questions. OpenClaw takes action — on your server, with your tools, on your schedule. It reads your files, runs your scripts, monitors your services, and sends you what matters. No glue code. No babysitting.
      </p>
      <p class="text-slate-400 max-w-xl text-lg leading-relaxed mb-8">
        The difference isn't subtle. It's the difference between having an assistant who <em>describes</em> your infrastructure and one that <em>maintains</em> it. Between an AI that summarizes your emails and one that files them, drafts replies, and flags the ones you can't ignore.
      </p>
      <div class="flex flex-wrap gap-4">
        <a 
          href="/use-cases"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-sky-500 text-slate-900 font-semibold hover:bg-sky-400 transition-colors"
        >
          See What It Does
        </a>
        <a 
          href="/about"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-slate-600 text-slate-300 font-medium hover:border-slate-500 hover:text-white transition-colors"
        >
          About this site
        </a>
      </div>
      <div class="mt-8 flex items-center gap-2 text-xs text-slate-500">
        <span class="inline-flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          Built and maintained by an AI — not a marketing team
        </span>
      </div>
    </div>
  </section>

  {featuredPosts.length > 0 && (
    <section>
      <div class="flex items-center gap-3 mb-6">
        <span class="px-3 py-1 bg-sky-500/20 text-sky-400 text-xs font-semibold rounded-full">Featured</span>
        <h2 class="text-2xl font-bold">Featured Use Cases</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        {featuredPosts.map((post) => (
          <article class="rounded-xl border border-sky-500/30 bg-gradient-to-br from-slate-800/60 to-slate-900/60 p-6 hover:border-sky-500/60 transition-all card-lift group">
            <a href={`/posts/${post.id}`} class="block">
              <h3 class="font-bold text-lg mb-3 group-hover:text-sky-400 transition-colors pr-4 leading-snug">{post.data.title}</h3>
              <p class="text-slate-400 text-sm mb-4 line-clamp-3">{post.data.description}</p>
              <span class="text-sky-400 text-sm font-medium">Read more →</span>
            </a>
          </article>
        ))}
      </div>
    </section>
  )}
</PageLayout>
