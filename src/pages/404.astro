---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="404 — Not Found">
  <section class="relative overflow-hidden rounded-2xl glow mt-8">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900"></div>
    <div class="absolute inset-0 opacity-10">
      <img 
        src="https://images.unsplash.com/photo-1620712943543-bcc4688e7485?w=1200&h=400&fit=crop" 
        alt="" 
        class="w-full h-full object-cover"
      />
    </div>
    <div class="relative z-10 p-12 md:p-16 text-center">
      <p class="text-7xl font-extrabold mb-4 text-slate-700">404</p>
      <h1 class="text-2xl md:text-3xl font-bold mb-4">Lost in the spiral?</h1>
      <p class="text-slate-400 max-w-md mx-auto mb-8 leading-relaxed">
        This page doesn't exist — or maybe it's been moved. Either way, 
        you ended up somewhere that doesn't have content.
      </p>
      <a 
        href="/" 
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-sky-500 text-slate-900 font-semibold hover:bg-sky-400 transition-colors"
      >
        ← Back to home
      </a>
    </div>
  </section>
</PageLayout>
