---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="404 — Not Found">
  <section class="relative overflow-hidden rounded-2xl glow mt-8">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900"></div>
    <div class="absolute inset-0 opacity-10">
      <img 
        src="https://images.unsplash.com/photo-1620712943543-bcc4688e7485?w=1200&h=400&fit=crop" 
        alt="" 
        class="w-full h-full object-cover"
      />
    </div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 80% at 50% 40%, rgba(56, 189, 248, 0.08) 0%, transparent 70%);"></div>
    <div class="relative z-10 p-12 md:p-16 text-center">
      <div class="flex items-center justify-center gap-3 mb-6">
        <span class="text-8xl font-extrabold text-slate-700 select-none" aria-hidden="true">4</span>
        <div class="relative w-16 h-16">
          <svg viewBox="0 0 64 64" class="w-full h-full animate-spin-slow" style="animation-duration: 12s;" xmlns="http://www.w3.org/2000/svg">
            <circle cx="32" cy="32" r="28" fill="none" stroke="#1e293b" stroke-width="6"/>
            <path d="M32 4 A28 28 0 0 1 60 32" fill="none" stroke="#38bdf8" stroke-width="6" stroke-linecap="round"/>
            <path d="M60 32 A28 28 0 0 1 32 60" fill="none" stroke="#818cf8" stroke-width="6" stroke-linecap="round"/>
            <path d="M32 60 A28 28 0 0 1 4 32" fill="none" stroke="#c084fc" stroke-width="6" stroke-linecap="round"/>
            <path d="M4 32 A28 28 0 0 1 32 4" fill="none" stroke="#38bdf8" stroke-width="6" stroke-linecap="round" opacity="0.5"/>
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-lg">🦎</span>
          </div>
        </div>
        <span class="text-8xl font-extrabold text-slate-700 select-none" aria-hidden="true">4</span>
      </div>
      <h1 class="text-2xl md:text-3xl font-bold mb-4">Lost in the spiral?</h1>
      <p class="text-slate-400 max-w-md mx-auto mb-8 leading-relaxed">
        This page doesn't exist — or maybe it's been moved. Either way, 
        you ended up somewhere that doesn't have content.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-sky-500 text-slate-900 font-semibold hover:bg-sky-400 transition-colors"
        >
          ← Back to home
        </a>
        <a 
          href="/use-cases" 
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-slate-700 text-slate-300 text-sm hover:border-slate-600 hover:text-white transition-colors"
        >
          Browse use cases
        </a>
      </div>
    </div>
  </section>
</PageLayout>
