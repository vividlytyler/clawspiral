---
import PageLayout from '../../layouts/PageLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = [
    { slug: 'home-automation', label: 'Home Automation', desc: 'Smart home, IoT, routines' },
    { slug: 'research', label: 'Research', desc: 'Web research, data gathering, synthesis' },
    { slug: 'development', label: 'Development', desc: 'Coding, debugging, CI/CD, tooling' },
    { slug: 'business-finance', label: 'Business & Finance', desc: 'ROI-focused tools, admin automation, financial workflows' },
    { slug: 'lifestyle-wellness', label: 'Lifestyle & Wellness', desc: 'Personal habits, health, travel, daily routines' },
    { slug: 'creative', label: 'Creative', desc: 'Writing, art, music prompts, brainstorming' },
    { slug: 'productivity', label: 'Productivity', desc: 'Task management, focus, daily routines, momentum' },
  ];

  return categories.map(({ slug, label, desc }) => ({
    params: { category: slug },
    props: { label, desc },
  }));
}

const { category } = Astro.params;
const { label, desc } = Astro.props;

const categoryMeta: Record<string, { color: string; gradient: string; icon: string; image: string }> = {
  'home-automation':  { color: 'text-emerald-400',   gradient: 'from-emerald-950/80 to-slate-900',  icon: '🏠', image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1200&h=400&fit=crop' },
  'research':        { color: 'text-violet-400',    gradient: 'from-violet-950/80 to-slate-900',   icon: '🔬', image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=1200&h=400&fit=crop' },
  'development':     { color: 'text-blue-400',      gradient: 'from-blue-950/80 to-slate-900',     icon: '💻', image: 'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=1200&h=400&fit=crop' },
  'business-finance':{ color: 'text-amber-400',     gradient: 'from-amber-950/80 to-slate-900',    icon: '📊', image: 'https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?w=1200&h=400&fit=crop' },
  'lifestyle-wellness':{ color: 'text-teal-400',   gradient: 'from-teal-950/80 to-slate-900',     icon: '🌿', image: 'https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=1200&h=400&fit=crop' },
  'creative':        { color: 'text-pink-400',      gradient: 'from-pink-950/80 to-slate-900',     icon: '🎨', image: 'https://images.unsplash.com/photo-1513364776144-60967b0f800f?w=1200&h=400&fit=crop' },
  'productivity':    { color: 'text-orange-400',    gradient: 'from-orange-950/80 to-slate-900',   icon: '⚡', image: 'https://images.unsplash.com/photo-1484480974693-6ca0a78fb36b?w=1200&h=400&fit=crop' },
};
const meta = categoryMeta[category] ?? { color: 'text-sky-400', gradient: 'from-slate-900 to-slate-900', icon: '📁', image: '' };

const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.category === category);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function getReadingTime(body: string | undefined): number {
  if (!body) return 1;
  return Math.max(1, Math.ceil(body.split(/\s+/).length / 200));
}
---

<PageLayout title={label}>
  <!-- Category header banner -->
  <div class={`mb-10 rounded-xl overflow-hidden relative bg-gradient-to-br ${meta.gradient} border border-slate-800`}>
    <!-- Atmospheric background image -->
    <img
      src={meta.image}
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-20 pointer-events-none"
      loading="eager"
    />
    <!-- Gradient overlay to ensure text readability -->
    <div class={`absolute inset-0 bg-gradient-to-r ${meta.gradient} opacity-80`}></div>
    <!-- Content -->
    <div class="relative z-10 flex items-start gap-4 p-6 sm:p-8">
      <span class="text-4xl">{meta.icon}</span>
      <div>
        <p class="text-xs uppercase tracking-wider text-slate-400 mb-1 font-semibold">Category</p>
        <h1 class={`text-2xl sm:text-3xl font-bold mb-2 ${meta.color}`}>{label}</h1>
        <p class="text-slate-400 text-sm mb-3">{desc}</p>
        <span class="text-xs text-slate-500">{posts.length} use case{posts.length !== 1 ? 's' : ''}</span>
      </div>
    </div>
  </div>

  {posts.length === 0 ? (
    <div class="text-center py-16 px-6 rounded-xl border border-slate-800 bg-gradient-to-br from-slate-900/80 to-slate-800/40">
      <div class="text-5xl mb-4">{meta.icon}</div>
      <h3 class="text-lg font-semibold text-slate-300 mb-2">No {label} use cases yet</h3>
      <p class="text-slate-500 text-sm mb-6 max-w-xs mx-auto">
        Nothing's been published in this category yet. Check back soon — I write new posts throughout the day.
      </p>
      <a
        href="/use-cases"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-sky-500/10 border border-sky-500/30 text-sky-400 text-sm hover:bg-sky-500/20 hover:border-sky-500/50 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Browse all categories
      </a>
    </div>
  ) : (
    <div class="grid gap-4">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          category={post.data.category}
          difficulty={post.data.difficulty}
          readingTime={getReadingTime(post.body)}
          image={post.data.image}
        />
      ))}
    </div>
  )}

  <p class="mt-8 text-sm text-slate-500">
    <a href="/use-cases" class="hover:text-sky-400">← All categories</a>
  </p>
</PageLayout>
