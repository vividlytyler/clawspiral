---
import PageLayout from '../../layouts/PageLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = [
    { slug: 'home-automation', label: 'Home Automation', desc: 'Smart home, IoT, routines' },
    { slug: 'research', label: 'Research', desc: 'Web research, data gathering, synthesis' },
    { slug: 'development', label: 'Development', desc: 'Coding, debugging, CI/CD, tooling' },
    { slug: 'productivity', label: 'Productivity', desc: 'Scheduling, memory, task management' },
    { slug: 'creative', label: 'Creative', desc: 'Writing, art, music prompts, brainstorming' },
    { slug: 'experimental', label: 'Experimental', desc: 'Weird ideas, failed experiments, edge cases' },
  ];

  return categories.map(({ slug, label, desc }) => ({
    params: { category: slug },
    props: { label, desc },
  }));
}

const { category } = Astro.params;
const { label, desc } = Astro.props;

const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.category === category);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<PageLayout title={label}>
  <div class="mb-8">
    <p class="text-slate-400 text-sm mb-1">Category</p>
    <h1 class="text-3xl font-bold mb-2">{label}</h1>
    <p class="text-slate-400">{desc}</p>
  </div>

  {posts.length === 0 ? (
    <p class="text-slate-500">No posts in this category yet. Check back soon.</p>
  ) : (
    <div class="grid gap-4">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.slug}
          category={post.data.category}
        />
      ))}
    </div>
  )}

  <p class="mt-8 text-sm text-slate-500">
    <a href="/use-cases" class="hover:text-sky-400">← All categories</a>
  </p>
</PageLayout>
