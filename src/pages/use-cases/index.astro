---
import PageLayout from '../../layouts/PageLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const featuredPosts = allPosts.filter((post) => post.data.featured).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function getReadingTime(body: string | undefined): number {
  if (!body) return 1;
  return Math.max(1, Math.ceil(body.split(/\s+/).length / 200));
}

const categoryColors: Record<string, { border: string; text: string; hover: string; gradient: string }> = {
  'home-automation': { border: 'border-emerald-500/40', text: 'text-emerald-400', hover: 'hover:border-emerald-500/70', gradient: 'from-emerald-950/30' },
  'research':        { border: 'border-violet-500/40', text: 'text-violet-400', hover: 'hover:border-violet-500/70', gradient: 'from-violet-950/30' },
  'development':     { border: 'border-blue-500/40',   text: 'text-blue-400',   hover: 'hover:border-blue-500/70',   gradient: 'from-blue-950/30' },
  'business-finance':{ border: 'border-amber-500/40',   text: 'text-amber-400',   hover: 'hover:border-amber-500/70',   gradient: 'from-amber-950/30' },
  'lifestyle-wellness':{ border: 'border-teal-500/40',  text: 'text-teal-400',    hover: 'hover:border-teal-500/70',    gradient: 'from-teal-950/30' },
  'creative':        { border: 'border-pink-500/40',   text: 'text-pink-400',    hover: 'hover:border-pink-500/70',   gradient: 'from-pink-950/30' },
};

const categories = [
  { slug: 'home-automation',  label: 'Home Automation',   desc: 'Smart home, IoT, routines' },
  { slug: 'research',         label: 'Research',          desc: 'Web research, data gathering, synthesis' },
  { slug: 'development',       label: 'Development',       desc: 'Coding, debugging, CI/CD, tooling' },
  { slug: 'business-finance', label: 'Business & Finance',desc: 'ROI-focused tools, admin automation, financial workflows' },
  { slug: 'lifestyle-wellness',label:'Lifestyle & Wellness',desc:'Personal habits, health, travel, daily routines' },
  { slug: 'creative',          label: 'Creative',          desc: 'Writing, art, music prompts, brainstorming' },
];

// Serialize posts for client-side search
const searchData = posts.map((post) => ({
  id: post.id,
  title: post.data.title,
  description: post.data.description,
  category: post.data.category,
  tags: post.data.tags ?? [],
  body: post.body?.replace(/[#*`>\[\]]/g, '').slice(0, 500) ?? '',
}));
---

<PageLayout title="Use Cases">
  <h1 class="text-3xl font-bold mb-6">Use Cases</h1>

  {featuredPosts.length > 0 && (
    <section class="mb-10">
      <div class="flex items-center gap-3 mb-5">
        <span class="px-3 py-1 bg-sky-500/20 text-sky-400 text-xs font-semibold rounded-full">Featured</span>
        <h2 class="text-xl font-bold">Featured Use Cases</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        {featuredPosts.map((post) => (
          <article class="rounded-xl border border-sky-500/30 bg-gradient-to-br from-slate-800/60 to-slate-900/60 p-5 hover:border-sky-500/60 transition-all card-lift group">
            <a href={`/posts/${post.id}`} class="block">
              <h3 class="font-bold text-base mb-2 group-hover:text-sky-400 transition-colors leading-snug">{post.data.title}</h3>
              <p class="text-slate-400 text-sm line-clamp-3">{post.data.description}</p>
              <span class="text-sky-400 text-sm font-medium mt-3 block">Read more →</span>
            </a>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-4">Browse by Category</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {categories.map(({ slug, label, desc }) => {
        const c = categoryColors[slug] ?? { border: 'border-slate-700', text: 'text-sky-400', hover: 'hover:border-slate-500', gradient: 'from-slate-900/30' };
        return (
          <a
            href={`/use-cases/${slug}`}
            class={`p-4 rounded-lg border ${c.border} ${c.hover} bg-gradient-to-br ${c.gradient} to-slate-900/60 transition-all group card-lift`}
          >
            <h3 class={`font-semibold ${c.text} mb-1 group-hover:translate-x-1 transition-transform text-sm`}>{label}</h3>
            <p class="text-slate-500 text-xs">{desc}</p>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Search -->
  <div class="mb-6">
    <div class="relative max-w-md">
      <input
        id="search-input"
        type="text"
        placeholder="Search use cases..."
        class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 pl-10 text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:border-sky-500 transition-colors"
      />
      <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    </div>
    <p id="search-count" class="text-xs text-slate-500 mt-2 hidden"></p>
  </div>

  <div id="posts-list" class="grid gap-4">
    {posts.map((post) => (
      <div data-post-id={post.id}>
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          category={post.data.category}
          difficulty={post.data.difficulty}
          readingTime={getReadingTime(post.body)}
          image={post.data.image}
        />
      </div>
    ))}
  </div>

  <div id="no-results" class="hidden text-center py-12 text-slate-500">
    No use cases match your search. Try different keywords.
  </div>
</PageLayout>

<script define:vars={{ searchData }}>
  const input = document.getElementById('search-input');
  const postsList = document.getElementById('posts-list');
  const noResults = document.getElementById('no-results');
  const searchCount = document.getElementById('search-count');

  function normalize(str) {
    return (str || '').toLowerCase();
  }

  function search(query) {
    const terms = normalize(query).split(/\s+/).filter(Boolean);
    if (terms.length === 0) {
      // Show all
      postsList.querySelectorAll('[data-post-id]').forEach((el) => {
        el.style.display = '';
      });
      noResults.classList.add('hidden');
      searchCount.classList.add('hidden');
      return;
    }

    let visible = 0;
    postsList.querySelectorAll('[data-post-id]').forEach((el) => {
      const id = el.dataset.postId;
      const post = searchData.find((p) => p.id === id);
      if (!post) return;

      const haystack = [post.title, post.description, post.category, post.tags.join(' '), post.body].join(' ');
      const matches = terms.every((term) => normalize(haystack).includes(term));

      el.style.display = matches ? '' : 'none';
      if (matches) visible++;
    });

    noResults.classList.toggle('hidden', visible > 0);
    searchCount.textContent = `${visible} result${visible !== 1 ? 's' : ''} found`;
    searchCount.classList.remove('hidden');
  }

  input.addEventListener('input', (e) => search(e.target.value));
</script>
